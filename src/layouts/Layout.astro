---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Bryan Sanchinell | Workforce Development Executive & Consultant',
  description = 'Bryan Sanchinell is a workforce development executive and consultant with 15+ years building recruitment, training, and career pathway programs.',
} = Astro.props;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/services', label: 'Services' },
  { href: '/impact', label: 'Impact' },
  { href: '/blog', label: 'Blog' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700;1,900&family=DM+Sans:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen flex flex-col">

    <!-- Navigation -->
    <header class="bg-[#0D2145] border-b border-[rgba(74,144,217,0.2)] sticky top-0 z-50">
      <nav class="max-w-6xl mx-auto px-6 flex items-center justify-between h-16">

        <a href="/" class="font-semibold text-lg tracking-tight hover:opacity-80 transition-opacity">
          <span class="text-white">Bryan</span> <span class="text-[#4A90D9]">Sanchinell</span>
        </a>

        <!-- Desktop links -->
        <div class="hidden md:flex items-center gap-7">
          {navLinks.map(({ href, label }) => (
            <a
              href={href}
              class={`text-sm font-medium transition-colors hover:text-[#4A90D9] ${
                currentPath === href || (href !== '/' && currentPath.startsWith(href))
                  ? 'text-[#4A90D9]'
                  : 'text-white/75'
              }`}
            >
              {label}
            </a>
          ))}
          <a
            href="/contact"
            class="ml-2 bg-[#4A90D9] text-white text-sm font-medium px-5 py-2 rounded-full hover:bg-[#3A7BC8] transition-colors"
          >
            Let's Talk
          </a>
        </div>

        <!-- Mobile hamburger -->
        <button id="menu-btn" class="md:hidden p-2 flex flex-col gap-1.5" aria-label="Toggle menu">
          <span class="w-5 h-0.5 bg-white block"></span>
          <span class="w-5 h-0.5 bg-white block"></span>
          <span class="w-5 h-0.5 bg-white block"></span>
        </button>
      </nav>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden border-t border-[rgba(74,144,217,0.2)] bg-[#0D2145] px-6 py-5 flex flex-col gap-4">
        {navLinks.map(({ href, label }) => (
          <a href={href} class="text-sm font-medium text-white/75 hover:text-[#4A90D9] transition-colors">
            {label}
          </a>
        ))}
        <a
          href="/contact"
          class="bg-[#4A90D9] text-white text-sm font-medium px-5 py-2.5 rounded-full hover:bg-[#3A7BC8] transition-colors text-center mt-1"
        >
          Let's Talk
        </a>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-[#060E1C] text-white">
      <div class="max-w-6xl mx-auto px-6 py-14">
        <div class="grid md:grid-cols-3 gap-10">
          <div>
            <p class="font-semibold text-lg">
              <span class="text-white">Bryan</span> <span class="text-[#4A90D9]">Sanchinell</span>
            </p>
            <p class="text-sm text-[#A8B4C8] mt-1 leading-relaxed">
              Workforce Development Executive &amp; Consultant<br />
              Bilingual · English &amp; Spanish
            </p>
            <a
              href="https://www.linkedin.com/in/bryan-sanchinell/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 mt-4 text-sm text-[#A8B4C8] hover:text-[#4A90D9] transition-colors"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
              </svg>
              LinkedIn
            </a>
          </div>

          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-[#A8B4C8]/60 mb-4">Pages</p>
            <div class="grid grid-cols-2 gap-x-6 gap-y-2">
              {navLinks.map(({ href, label }) => (
                <a href={href} class="text-sm text-[#A8B4C8] hover:text-white transition-colors">
                  {label}
                </a>
              ))}
            </div>
          </div>

          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-[#A8B4C8]/60 mb-4">Focus Areas</p>
            <ul class="space-y-2 text-sm text-[#A8B4C8]">
              <li>Workforce Systems Design</li>
              <li>Recruitment &amp; Outreach</li>
              <li>Job Placement Programs</li>
              <li>Leadership Development</li>
              <li>Apprenticeship Standards</li>
            </ul>
          </div>
        </div>

        <div class="border-t border-white/10 mt-12 pt-6 text-center text-xs text-[#A8B4C8]/40">
          © {new Date().getFullYear()} <span class="text-[#C9A84C]">Bryan Sanchinell</span>. All rights reserved.
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
    </script>

  </body>
</html>
