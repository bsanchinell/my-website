---
import Layout from '../layouts/Layout.astro';

const caseStudies = [
  {
    tag: 'Higher Education · NYC',
    org: 'CUNY UX Design Program',
    role: 'Kingsborough Community College',
    period: '2017–2020',
    headline: 'Launched CUNY\'s First UX Design Training Program',
    body: 'Designed and launched the first-ever UX Design training program within the CUNY system, building curriculum, employer partnerships, and recruitment infrastructure from the ground up. Created a replicable model for tech-sector workforce development in higher education.',
    outcomes: [
      { label: 'Registration Increase', value: '556%' },
      { label: 'Completion Rate', value: '80%' },
      { label: 'Women Enrolled', value: '67%' },
    ],
    partners: ['Spotify', 'Google'],
  },
  {
    tag: 'Industry · National',
    org: 'National Talent Hub',
    role: 'NIIT / SEMI Americas',
    period: '2020–2023',
    headline: 'Directed $6M NSF Grant to Build a National Skills Platform',
    body: 'Directed a $6 million NSF-funded initiative to develop a SaaS platform that aligned employer job descriptions, college learning outcomes, and industry skills standards for the semiconductor sector. Built cross-state workforce pipelines across NY, NC, and TX.',
    outcomes: [
      { label: 'Grant Managed', value: '$6M+' },
      { label: 'States Served', value: '3' },
      { label: 'Industry Focus', value: 'Semi.' },
    ],
    partners: ['NSF', 'SEMI Americas', 'NIIT'],
  },
  {
    tag: 'Labor · National Standards',
    org: '911 Dispatcher Apprenticeship',
    role: 'AFSCME IU',
    period: '2025–Present',
    headline: 'Designed the First-Ever National Guideline Standards for 911 Dispatchers',
    body: 'Led the development of National Guideline Standards establishing industry benchmarks for 911 dispatcher competencies, creating the foundation for a recognized career pathway in public safety communications. This first-of-its-kind framework provides a model for apprenticeship and workforce development in emergency services.',
    outcomes: [
      { label: 'Industry First', value: '✓' },
      { label: 'Scope', value: 'National' },
      { label: 'Sector', value: 'Public Safety' },
    ],
    partners: ['AFSCME', 'DOL'],
  },
  {
    tag: 'Youth Workforce · Brooklyn',
    org: 'CHAMPION Network',
    role: 'Cypress Hills LDC',
    period: '2011–2017',
    headline: 'Created a Leadership Employment Program With 92% One-Year Retention',
    body: 'Founded and directed the CHAMPION Network, a leadership development and employment program for young adults in East New York, Brooklyn. Combined T-group facilitation, job readiness training, and employer partnerships to deliver one of the highest retention rates in the sector.',
    outcomes: [
      { label: 'Young Adults Placed', value: '95+' },
      { label: '1-Year Retention', value: '92%' },
      { label: 'Program Duration', value: '6 yrs' },
    ],
    partners: ['NYC DYCD', 'Cypress Hills LDC'],
  },
];

const metrics = [
  { value: '$6M+', label: 'Grant Budgets Managed' },
  { value: '556%', label: 'Recruitment Increase' },
  { value: '95+', label: 'Young Adults Placed' },
  { value: '92%', label: 'One-Year Retention Rate' },
  { value: '9', label: 'Programs Optimized' },
  { value: '15+', label: 'Years of Experience' },
];

const publications = [
  {
    title: 'Why Most Workforce Programs Fail Before They Start: A Systems Design Perspective',
    tag: 'Systems Design',
    date: 'February 2025',
  },
  {
    title: 'From Recruitment to Retention: Building Career Pathways That Actually Stick',
    tag: 'Career Pathways',
    date: 'January 2025',
  },
  {
    title: 'Design Thinking for Workforce Professionals: Putting Workers at the Center',
    tag: 'Design Thinking',
    date: 'December 2024',
  },
];
---

<Layout
  title="Impact | Bryan Sanchinell"
  description="Real workforce development results: case studies on CUNY UX Design, NSF National Talent Hub, AFSCME 911 apprenticeship standards, and the CHAMPION Network."
>

  <!-- 1. NAVY — Hero -->
  <section class="bg-[#0D2145] pt-24 pb-20 px-6 md:px-12">
    <div class="max-w-4xl mx-auto">
      <p class="text-xs font-semibold uppercase tracking-widest text-[#4A90D9] mb-5">Results</p>
      <h1 class="text-4xl md:text-5xl font-bold text-white leading-tight mb-5">
        Real Programs.<br />Real Results.
      </h1>
      <p class="text-lg text-[#A8B4C8] max-w-2xl leading-relaxed">
        Fifteen years of work that moved people into better opportunities and helped
        organizations build systems that lasted.
      </p>
    </div>
  </section>

  <!-- 2. WHITE — Metrics Bar -->
  <section class="bg-white border-t border-[#E2E8F0] py-16 px-6 md:px-12">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 divide-y-2 md:divide-y-0 md:divide-x divide-[#E2E8F0]">
        {metrics.map(({ value, label }) => (
          <div class="text-center py-6 md:py-0 px-4">
            <p class="text-2xl md:text-3xl font-bold text-[#0D2145]">{value}</p>
            <p class="text-xs text-[#64748B] mt-1 leading-snug">{label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 3. NAVY — Case Studies 2×2 grid -->
  <section class="bg-[#0D2145] py-16 px-6 md:px-12">
    <div class="max-w-5xl mx-auto">
      <p class="text-xs font-semibold uppercase tracking-widest text-[#4A90D9] mb-3">Case Studies</p>
      <h2 class="text-3xl font-bold text-white mb-10">Work That Moved the Needle</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {caseStudies.map(({ tag, org, role, period, headline, body, outcomes, partners }) => (
          <div class="bg-[#1A3060] rounded-2xl border border-[rgba(74,144,217,0.15)] hover:border-[rgba(74,144,217,0.45)] overflow-hidden hover:shadow-lg transition-all duration-200 flex flex-col">
            <div class="h-1 bg-[#4A90D9]"></div>
            <div class="p-7 flex flex-col flex-1">
              <div class="mb-4">
                <span class="text-xs font-semibold uppercase tracking-widest text-[#4A90D9]">
                  {tag}
                </span>
                <h3 class="text-lg font-bold text-white mt-1">{org}</h3>
                <p class="text-xs text-[#A8B4C8] mt-0.5">{role} · {period}</p>
              </div>
              <p class="text-sm font-semibold text-white mb-2 leading-snug">{headline}</p>
              <p class="text-sm text-[#A8B4C8] leading-relaxed mb-6 flex-1">{body}</p>
              <div class="grid grid-cols-3 gap-3 mb-4">
                {outcomes.map(({ label, value }) => (
                  <div class="rounded-lg p-3 text-center bg-[rgba(74,144,217,0.1)]">
                    <p class="text-base font-bold text-[#4A90D9]">{value}</p>
                    <p class="text-[10px] text-[#A8B4C8] mt-0.5 leading-snug">{label}</p>
                  </div>
                ))}
              </div>
              <div class="flex flex-wrap gap-1.5">
                {partners.map((p) => (
                  <span class="text-xs bg-[rgba(74,144,217,0.08)] border border-[rgba(74,144,217,0.2)] text-[#A8B4C8] px-2.5 py-0.5 rounded-full">
                    {p}
                  </span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. WHITE — Publications -->
  <section class="bg-white border-t border-[#E2E8F0] py-16 px-6 md:px-12">
    <div class="max-w-5xl mx-auto">
      <p class="text-xs font-semibold uppercase tracking-widest text-[#4A90D9] mb-3">Writing</p>
      <h2 class="text-3xl font-bold text-[#0D2145] mb-10">Publications &amp; Insights</h2>
      <div class="space-y-4">
        {publications.map(({ title, tag, date }) => (
          <a
            href="https://www.linkedin.com/in/bryan-sanchinell/"
            target="_blank"
            rel="noopener noreferrer"
            class="block bg-[#F5F2EC] rounded-xl p-6 border border-[#E2E8F0] border-l-4 border-l-[#4A90D9] hover:shadow-md transition-all duration-200 group"
          >
            <div class="flex flex-wrap items-center gap-3 mb-2">
              <span class="text-xs font-medium text-[#4A90D9] bg-white border border-[#E2E8F0] px-3 py-0.5 rounded-full">
                {tag}
              </span>
              <span class="text-xs text-[#64748B]">{date}</span>
            </div>
            <p class="text-sm font-semibold text-[#0D2145] leading-snug group-hover:text-[#4A90D9] transition-colors">
              {title}
            </p>
          </a>
        ))}
      </div>
      <div class="mt-8 text-center">
        <a
          href="/blog"
          class="inline-flex items-center gap-2 text-[#4A90D9] font-medium text-sm hover:gap-3 transition-all"
        >
          View all writing
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

</Layout>
