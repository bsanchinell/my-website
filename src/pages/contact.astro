---
import Layout from '../layouts/Layout.astro';
import { client } from '../lib/sanity';

const sanity = await client.fetch(`*[_type == "contact"][0]`).catch(() => null);

const introText = sanity?.introText ??
  'Whether you\'re looking to redesign a program, build a talent pipeline, or develop your team — I\'d love to hear what you\'re working on.';

const defaultChecklist = [
  'A response within 2 business days',
  'An initial 30-minute discovery call',
  'A tailored proposal based on your needs',
  'Flexible engagement formats',
];

const checklistItems: string[] = (sanity?.checklistItems?.length > 0)
  ? sanity.checklistItems
  : defaultChecklist;
---

<Layout
  title="Contact | Bryan Sanchinell"
  description="Get in touch with Bryan Sanchinell to discuss your workforce development needs, program design, or consulting engagement."
>

  <!-- 1. NAVY — Hero -->
  <section class="bg-[#0D2145] pt-24 pb-20 px-6 md:px-12">
    <div class="max-w-4xl mx-auto">
      <p class="text-xs font-semibold uppercase tracking-widest text-[#4A90D9] mb-5">Get in Touch</p>
      <h1 class="text-4xl md:text-5xl font-bold text-white leading-tight mb-5">
        Let's Talk About Your<br class="hidden md:block" /> Workforce Challenge
      </h1>
      <p class="text-lg text-[#A8B4C8] max-w-2xl leading-relaxed">
        {introText}
      </p>
    </div>
  </section>

  <!-- 2. WHITE — Form + Info -->
  <section class="bg-white border-t border-[#E2E8F0] py-16 px-6 md:px-12">
    <div class="max-w-5xl mx-auto grid md:grid-cols-5 gap-14">

      <!-- Left: Form (3 cols) -->
      <div class="md:col-span-3">
        <form
          action="https://formspree.io/f/xbdprgdv"
          method="POST"
          class="space-y-6"
        >
          <div class="grid sm:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-xs font-semibold uppercase tracking-wider text-[#64748B] mb-2">
                Name <span class="text-[#4A90D9]">*</span>
              </label>
              <input
                id="name"
                name="name"
                type="text"
                required
                placeholder="Your full name"
                class="w-full bg-[#FAFAFA] border border-[#E2E8F0] rounded-xl px-4 py-3 text-sm text-[#0D2145] placeholder:text-[#94A3B8] focus:outline-none focus:ring-2 focus:ring-[#4A90D9]/30 focus:border-[#4A90D9] transition-colors"
              />
            </div>
            <div>
              <label for="org" class="block text-xs font-semibold uppercase tracking-wider text-[#64748B] mb-2">
                Organization
              </label>
              <input
                id="org"
                name="organization"
                type="text"
                placeholder="Your organization"
                class="w-full bg-[#FAFAFA] border border-[#E2E8F0] rounded-xl px-4 py-3 text-sm text-[#0D2145] placeholder:text-[#94A3B8] focus:outline-none focus:ring-2 focus:ring-[#4A90D9]/30 focus:border-[#4A90D9] transition-colors"
              />
            </div>
          </div>

          <div>
            <label for="email" class="block text-xs font-semibold uppercase tracking-wider text-[#64748B] mb-2">
              Email <span class="text-[#4A90D9]">*</span>
            </label>
            <input
              id="email"
              name="email"
              type="email"
              required
              placeholder="your@email.com"
              class="w-full bg-[#FAFAFA] border border-[#E2E8F0] rounded-xl px-4 py-3 text-sm text-[#0D2145] placeholder:text-[#94A3B8] focus:outline-none focus:ring-2 focus:ring-[#4A90D9]/30 focus:border-[#4A90D9] transition-colors"
            />
          </div>

          <div>
            <label for="message" class="block text-xs font-semibold uppercase tracking-wider text-[#64748B] mb-2">
              What are you working on? <span class="text-[#4A90D9]">*</span>
            </label>
            <textarea
              id="message"
              name="message"
              required
              rows="6"
              placeholder="Tell me about your organization, what you're trying to solve, and how I might help..."
              class="w-full bg-[#FAFAFA] border border-[#E2E8F0] rounded-xl px-4 py-3 text-sm text-[#0D2145] placeholder:text-[#94A3B8] focus:outline-none focus:ring-2 focus:ring-[#4A90D9]/30 focus:border-[#4A90D9] transition-colors resize-none"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-[#4A90D9] text-white font-semibold py-3.5 rounded-full hover:bg-[#3A7BC8] transition-colors text-sm"
          >
            Send Message
          </button>

          <p class="text-xs text-[#94A3B8] text-center">
            I typically respond within 2 business days.
          </p>
        </form>
      </div>

      <!-- Right: Info (2 cols) -->
      <div class="md:col-span-2 space-y-6">

        <!-- What to expect checklist -->
        <div class="bg-[#F5F2EC] rounded-2xl p-6 border border-[#E2E8F0]">
          <p class="text-xs font-semibold uppercase tracking-widest text-[#4A90D9] mb-4">What to expect</p>
          <ul class="space-y-3">
            {checklistItems.map((item) => (
              <li class="flex items-start gap-3 text-sm text-[#4A5568]">
                <span class="w-5 h-5 rounded-full bg-[#4A90D9]/10 text-[#4A90D9] flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                </span>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Based in NY -->
        <div class="bg-[#F5F2EC] rounded-2xl p-6 border border-[#E2E8F0]">
          <p class="text-sm font-semibold text-[#0D2145] mb-2">Based in New York</p>
          <p class="text-xs text-[#4A5568] leading-relaxed">
            Available for consulting engagements nationally. Fluent in English and Spanish —
            happy to connect in either language.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- 3. NAVY — LinkedIn Strip -->
  <section class="bg-[#0D2145] py-12 px-6 md:px-12">
    <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-6">
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-[#4A90D9] mb-1">Connect directly</p>
        <p class="text-[#A8B4C8] text-sm">linkedin.com/in/bryan-sanchinell</p>
      </div>
      <a
        href="https://www.linkedin.com/in/bryan-sanchinell/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 text-sm font-medium text-[#A8B4C8] hover:text-white transition-colors group flex-shrink-0"
      >
        <span class="w-9 h-9 rounded-full bg-[#0A66C2] text-white flex items-center justify-center">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
          </svg>
        </span>
        Connect on LinkedIn
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>

</Layout>
