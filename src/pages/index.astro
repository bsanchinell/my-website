---
import Layout from '../layouts/Layout.astro';
import { client } from '../lib/sanity';

const sanity = await client.fetch(`*[_type == "homepage"][0]`).catch(() => null);

const heroSubheadline = sanity?.heroSubheadline ??
  '15+ years building recruitment, training, and career pathway programs that deliver real results for workers and organizations.';

const aboutBio = sanity?.aboutBio ??
  'Bryan Sanchinell is a leader and workforce development strategist who applies design thinking and product management frameworks to build programs that center workers while delivering measurable outcomes. He is a Fellow of the Aspen Institute Sector Skills Academy and bilingual in English and Spanish.';

const stats = [
  { stat: sanity?.stats?.budgets   ?? '$6M+',    label: 'Budgets Managed' },
  { stat: sanity?.stats?.recruitment ?? '556%',  label: 'Recruitment Increase' },
  { stat: sanity?.stats?.retention ?? '85–92%',  label: 'Job Retention Rates' },
  { stat: sanity?.stats?.programs  ?? '9',       label: 'Programs Optimized' },
];
---

<Layout title="Bryan Sanchinell | Workforce Development Executive & Consultant">

  <!-- 1. NAVY — Hero -->
  <section class="bg-[#0D2145] pt-24 pb-28 px-6 md:px-12">
    <div class="max-w-4xl mx-auto text-center">
      <p class="inline-block text-[#4A90D9] font-medium text-xs uppercase tracking-widest mb-5 border border-[#4A90D9]/30 rounded-full px-4 py-1.5">
        Workforce Development · Strategy · Systems Design
      </p>
      <h1 class="text-4xl md:text-6xl font-bold text-white leading-tight mb-6">
        Designing Workforce Systems<br class="hidden md:block" />
        That <span class="italic text-[#C9A84C]">Work</span> for People
      </h1>
      <p class="text-lg md:text-xl text-[#A8B4C8] max-w-2xl mx-auto mb-10 leading-relaxed">
        {heroSubheadline}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/services"
          class="bg-[#4A90D9] text-white font-semibold px-8 py-3.5 rounded-full hover:bg-[#3A7BC8] transition-colors text-sm"
        >
          Explore Services
        </a>
        <a
          href="/about"
          class="border border-white/25 text-white font-medium px-8 py-3.5 rounded-full hover:border-[#4A90D9] hover:text-[#4A90D9] transition-colors text-sm"
        >
          About Bryan
        </a>
      </div>
    </div>
  </section>

  <!-- 2. WHITE — Stats Bar -->
  <section class="bg-white border-t border-[#E2E8F0] py-16 px-6 md:px-12">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-2 md:grid-cols-4 divide-y md:divide-y-0 md:divide-x divide-[#E2E8F0]">
        {stats.map(({ stat, label }) => (
          <div class="text-center py-6 md:py-0 px-6">
            <p class="text-3xl md:text-4xl font-bold text-[#0D2145]">{stat}</p>
            <p class="text-sm text-[#64748B] mt-1.5">{label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 3. NAVY — Who I Help -->
  <section class="bg-[#0D2145] py-16 px-6 md:px-12">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Who I Help</h2>
        <p class="text-[#A8B4C8] max-w-xl mx-auto leading-relaxed">
          I partner with organizations at every stage of workforce system development — from
          design to scale.
        </p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {[
          {
            emoji: '🤝',
            title: 'Nonprofits & CBOs',
            body: 'Building program infrastructure, scaling outreach, and improving job placement rates for community-based workforce programs that center worker voice.',
          },
          {
            emoji: '🏛️',
            title: 'Government Agencies & Unions',
            body: 'Designing apprenticeship standards, career pathway frameworks, and leadership development systems for public sector and labor organizations.',
          },
          {
            emoji: '🏭',
            title: 'Employers & Industry Partners',
            body: 'Creating talent pipelines, upskilling programs, and retention strategies aligned to real hiring needs and long-term workforce gaps.',
          },
        ].map(({ emoji, title, body }) => (
          <div class="bg-[#1A3060] rounded-2xl p-8 border border-[rgba(74,144,217,0.15)] hover:border-[rgba(74,144,217,0.45)] hover:shadow-lg transition-all duration-200 group cursor-default">
            <span class="text-3xl mb-5 block">{emoji}</span>
            <h3 class="text-lg font-semibold text-white mb-3 group-hover:text-[#4A90D9] transition-colors">
              {title}
            </h3>
            <p class="text-[#A8B4C8] text-sm leading-relaxed">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. WHITE — About Bryan Preview -->
  <section class="bg-white border-t border-[#E2E8F0] py-16 px-6 md:px-12">
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-16 items-center">
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-[#4A90D9] mb-4">About Bryan</p>
        <h2 class="text-3xl font-bold text-[#0D2145] mb-5 leading-snug">
          Worker-Centered.<br />Data-Driven.<br />Systems-Focused.
        </h2>
        <p class="text-[#4A5568] leading-relaxed mb-8">
          {aboutBio}
        </p>
        <a
          href="/about"
          class="inline-flex items-center gap-2 text-[#4A90D9] font-medium text-sm hover:gap-3 transition-all"
        >
          Read the full story
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
      <div class="grid grid-cols-2 gap-4">
        {[
          { label: 'Years of Experience', value: '15+' },
          { label: 'Sectors Served', value: '5+' },
          { label: 'Young Adults Placed', value: '95+' },
          { label: 'Aspen Institute Fellow', value: '✓' },
        ].map(({ label, value }) => (
          <div class="bg-white rounded-xl p-5 border border-[#E2E8F0]">
            <p class="text-2xl font-bold text-[#0D2145]">{value}</p>
            <p class="text-xs text-[#64748B] mt-1 leading-snug">{label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 5. NAVY — CTA -->
  <section class="bg-[#0D2145] py-16 px-6 md:px-12">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-xs font-semibold uppercase tracking-widest text-[#4A90D9] mb-4">Get Started</p>
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        Ready to transform your workforce programs?
      </h2>
      <p class="text-[#A8B4C8] text-lg mb-10 max-w-xl mx-auto leading-relaxed">
        Let's talk about your goals and build something that actually works for the people
        you serve.
      </p>
      <a
        href="/contact"
        class="inline-block bg-[#4A90D9] text-white font-semibold px-9 py-3.5 rounded-full hover:bg-[#3A7BC8] transition-colors text-sm"
      >
        Start a Conversation
      </a>
    </div>
  </section>

</Layout>
